{{ 'chat.css' | asset_url | stylesheet_tag }}
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

<div class="shop-ai-chat-container">
  <button type="button" class="shop-ai-chat-bubble" aria-label="{{ 'chat.openButton' | t }}">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 36" width="36" height="36" aria-hidden="true" focusable="false">
      <path d="M14.5 6.5L17.4 13.1L24 16L17.4 18.9L14.5 25.5L11.6 18.9L5 16L11.6 13.1L14.5 6.5Z"/>
      <path d="M25.5 20.5L27.1 24.4L31 26L27.1 27.6L25.5 31.5L23.9 27.6L20 26L23.9 24.4L25.5 20.5Z"/>
      <path d="M25.5 4.5L26.7 7.3L29.5 8.5L26.7 9.7L25.5 12.5L24.3 9.7L21.5 8.5L24.3 7.3L25.5 4.5Z"/>
    </svg>
  </button>

  <div class="shop-ai-chat-window">
    <div class="shop-ai-chat-header">
      <div>{{ 'chat.title' | t }}</div>
      <button type="button" class="shop-ai-chat-close">✕</button>
    </div>

    <div class="shop-ai-chat-tabs" role="tablist" aria-label="Chat mode">
      <button type="button" class="shop-ai-chat-tab active" data-chat-tab="shopping" role="tab" aria-selected="true">Shopping Assistant</button>
      <button type="button" class="shop-ai-chat-tab" data-chat-tab="support" role="tab" aria-selected="false">Support Team</button>
    </div>

    <div class="shop-ai-chat-tab-panel shop-ai-chat-tab-panel--shopping active" data-chat-panel="shopping" role="tabpanel">
      <div class="shop-ai-chat-messages">
        <!-- Messages will be added here by JavaScript -->
      </div>

      <div class="shop-ai-chat-input">
        <input type="text" placeholder="{{ 'chat.inputPlaceholder' | t }}">
        <button class="shop-ai-chat-send">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </div>
    </div>

    <div class="shop-ai-chat-tab-panel shop-ai-chat-tab-panel--support" data-chat-panel="support" role="tabpanel" hidden>
      <div class="shop-ai-support-content"></div>
    </div>
  </div>
</div>

<script src="{{ 'chat.js' | asset_url }}" defer></script>
<script>
  window.shopChatConfig = {
    promptType: "standardAssistant",
    shopDomain: {{ shop.permanent_domain | json }},
    apiBaseUrl: "https://shop-chat-agent-976732686346.asia-southeast1.run.app",
    bubblePosition: "right",
    bubbleBottomPx: 20,
    bubbleLeftPx: 20,
    bubbleRightPx: 20
  };
  window.shopId = {{ shop.id }};
</script>

{% schema %}
{
  "name": "AI Chat Assistant",
  "target": "body",
  "settings": []
}
{% endschema %}
